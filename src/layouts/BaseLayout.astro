---
import SiteFooter from '../components/astro/SiteFooter.astro';
import SiteHeader from '../components/svelte/SiteHeader.svelte';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	noindex?: boolean;
}

const {
	title = 'Investigations Plus Ltd',
	description = 'Toronto Private Investigators - expert private investigation services in GTA, Ontario, and beyond.',
	noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL.href} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
	</head>
	<body>
		<a class="sr-only" href="#main-content">Skip to content</a>
		<SiteHeader client:load currentPath={currentPath} />
		<main id="main-content" class="site-main">
			<slot />
		</main>
		<SiteFooter />
	</body>
</html>
